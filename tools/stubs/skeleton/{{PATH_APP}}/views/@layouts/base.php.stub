    <link rel="stylesheet" href="<?= Url::get('/css/style.css') ?>">
</head>
<body>
    <header>
        <div class="container">
            <a href="<?= Url::get('/') ?>" class="brand">
                <img src="<?= Url::get('/images/logo.svg') ?>" alt="Logo" class="logo">
                <span><?= Env::get('app.name', '{{APP_NAME}}') ?></span>
            </a>
            <button class="menu-toggle" id="menu-toggle">
                <span></span>
